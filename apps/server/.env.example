NODE_ENV=development
PORT=4000
DATABASE_URL="file:../data/serietime.sqlite"
APP_NAME="PlotTime"
APP_URL="http://localhost:4000"
# Adresse de contact/support affichée sur les pages légales (mailto). Vide =
# repli neutre. À POSER en prod avant la review des stores.
SUPPORT_EMAIL=""
APP_SECRET="change-me"
JWT_SECRET="change-me"
SESSION_DURATION_DAYS=30
# Inscription e-mail publique. En prod stores : "false" (politique SSO only) ;
# le LOGIN e-mail reste toujours ouvert (utile pour le compte de démo review).
ALLOW_EMAIL_SIGNUP="true"
TMDB_API_KEY=""
TMDB_READ_ACCESS_TOKEN=""

# SSO WEB (optionnel) — laissez vide pour n'utiliser que l'e-mail / mot de passe.
# GOOGLE_CLIENT_IDS = Client IDs OAuth acceptés (Web/Android/iOS), séparés par des virgules.
GOOGLE_CLIENT_IDS=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# SSO NATIF (builds App Store / Play) — voir docs/STORES.md.
# APPLE_BUNDLE_ID : défaut com.plottime.app (= app.json). Sign in with Apple marche sans le poser.
APPLE_BUNDLE_ID="com.plottime.app"
# Google natif : client IDs iOS/Android créés dans Google Cloud Console.
# ⚠️ Pensez à AUSSI les ajouter à GOOGLE_CLIENT_IDS (contrôle d'audience du jeton).
GOOGLE_IOS_CLIENT_ID=""
GOOGLE_ANDROID_CLIENT_ID=""
# Discord natif : même app que le web (PKCE, pas de secret). Redirect natif à
# déclarer côté Discord : serietime://oauth/discord
DISCORD_CLIENT_ID=""

TVMAZE_ENABLED=true
TVDB_ENABLED=false
TVDB_API_KEY=""
TVDB_PIN=""
DEFAULT_LANGUAGE="fr-FR"
DEFAULT_COUNTRY="FR"
DEFAULT_TIMEZONE="Europe/Paris"
MAX_IMPORT_ZIP_SIZE_MB=100
CORS_ALLOWED_ORIGINS="http://localhost:5173,capacitor://localhost,https://localhost"
